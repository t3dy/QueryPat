  "linked_names": [],
  "evidence_excerpts": [
    {
      "text": "There's another revealed element in \"Tears\" that I've forgotten about for years; not the element of prison & police but _slave labor_. In 3-74 it was revealed to me that this was the true goal of evil - not just slavery but slave _labor_. & this was distinctly related to the Xtian Basic Goal : not only to promote Freedom but to end slave labor. This is the basic historical issue. The Basic Fight. & a _slave labor state_ is shown in \"Tears.\"\n\nThis is absolutely fundamental in the corpus of revela",
      "matched_alias": "Sein",
      "term_id": "TERM_sein",
      "term_name": "Sein",
      "term_slug": "sein"
    }
  ],
